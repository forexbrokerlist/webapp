generator client {
  provider        = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "client"
  output          = "../.generated/prisma"
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

enum AdType {
  Banner
  Tools
  ToolPage
  BlogPost
  Bottom
  All
}

enum SponsorCategory {
  BrokerListing
  AlgoSelling
  Education
}

enum ToolStatus {
  Draft
  Scheduled
  Pending
  Published
}

enum ToolTier {
  Free
  Standard
  Premium
}

enum AdStatus {
  Draft
  Scheduled
  Pending
  Published
}

enum SubscriptionStatus {
  Active
  Expired
  Cancelled
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Cancelled
}

enum ClaimStatus {
  Pending
  Approved
  Rejected
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts  Account[]
  sessions  Session[]
  tools     Tool[]
  bookmarks Bookmark[]
  brokers   Brokers[]
  posts     Post[]
  payments  Payment[]
  claims    BrokerClaim[]

  // Indexes
  @@index([id])
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Ad {
  id          String   @id @default(cuid())
  email       String
  name        String
  description String?
  websiteUrl  String
  faviconUrl  String?
  bannerUrl   String?
  buttonLabel String?
  type        AdType   @default(All)
  startsAt    DateTime
  endsAt      DateTime
  sessionId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      AdStatus @default(Draft)
  clicks      Int      @default(0)
  impressions Int      @default(0)

  // Relations
  categoryId    String?
  Category      Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  Subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
}

model Tool {
  id             String     @id @default(cuid())
  name           String     @db.Citext
  slug           String     @unique
  websiteUrl     String
  affiliateUrl   String?
  tagline        String?
  description    String?
  content        String?
  faviconUrl     String?
  screenshotUrl  String?
  tier           ToolTier   @default(Free)
  tierPriority   Int        @default(dbgenerated())
  submitterName  String?
  submitterEmail String?
  submitterNote  String?
  status         ToolStatus @default(Draft)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  categories    Category[]
  subcategories Subcategory[]
  tags          Tag[]
  reports       Report[]
  owner         User?         @relation(fields: [ownerId], references: [id])
  ownerId       String?

  @@index([id, slug])
  @@index([name])
  @@index([status])
  @@index([ownerId])
  @@index([tierPriority, publishedAt])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @db.Citext
  slug        String   @unique
  label       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
   
  // Relations
  subcategories Subcategory[]
  tools         Tool[]
  brokers       Brokers[]
  sponsors      Sponsor[]
  ads           Ad[]

  // Indexes
  @@index([slug])
}
model Type{
  id String @id @default(cuid())
  name        String   @db.Citext
  
  slug String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
   label       String?
  description String?
  brokers       Brokers[]
}

model Subcategory {
  id          String   @id @default(cuid())
  name        String   @db.Citext
  slug        String   @unique
  label       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation to category
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Relations to items
  tools   Tool[]
  brokers Brokers[]
  ads     Ad[]

  // Indexes
  @@index([slug])
  @@index([categoryId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @db.Citext
  slug      String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // Relations
  tools   Tool[]
  brokers Brokers[]

  // Indexes
  @@index([name])
}

model Report {
  id        String   @id @default(cuid())
  type      String   @default("Other")
  message   String?
  email     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tool   Tool?   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String?

  // Indexes
  @@index([toolId])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  broker   Brokers @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  brokerId Int

  // Indexes
  @@unique([userId, brokerId])
  @@index([userId])
  @@index([brokerId])
}

model Brokers {
  id                                 Int        @id @default(autoincrement())
  average_trading_cost_bitcoin       String?    @db.VarChar(82)
  average_trading_cost_eur_usd       String?    @db.VarChar(95)
  average_trading_cost_gbp_usd       String?    @db.VarChar(95)
  average_trading_cost_gold          String?    @db.VarChar(92)
  average_trading_cost_wti_crude_oil String?    @db.VarChar(92)
  broker_name                        String?    @db.VarChar(50)
  cons                               String?
  daily_loss_limit                   String?    @db.VarChar(44)
  deposit_options                    String?    @db.VarChar(111)
  description                        String?
  subtitle                           String?
  execution_types                    String?    @db.VarChar(65)
  funded_account_options             String?    @db.VarChar(66)
  funding_methods                    String?    @db.VarChar(213)
  headquarters                       String?    @db.VarChar(63)
  minimum_commission_for_forex       String?    @db.VarChar(101)
  minimum_deposit                    String?    @db.VarChar(68)
  minimum_raw_spreads                String?    @db.VarChar(46)
  minimum_standard_spreads           String?    @db.VarChar(34)
  overall_rating                     String?    @db.VarChar(25)
  profit_share                       String?    @db.VarChar(44)
  pros                               String?
  regulators                         String?    @db.VarChar(88)
  regulators_table                   String?
  retail_loss_rate                   String?    @db.VarChar(49)
  scraped_at                         DateTime?  @db.Timestamp(6)
  trader_table                       String?
  trading_hours                      String?
  trading_platforms                  String?    @db.VarChar(98)
  url                                String?    @db.VarChar(98)
  withdrawal_options                 String?    @db.VarChar(111)
  year_established                   Float?
  deposit_fees                       String?
  inactivity_fee                     String?
  maximum_evaluation_fee             String?
  withdrawal_fee                     String?
  broker_website                     String?
  slug                               String?    @unique
  screenshotUrl                      String?
  order                              Int        @default(0)
  isSponsor                          Boolean    @default(false)
  isMainSponsor                      Boolean    @default(false)
  bookmarks                          Bookmark[]
  typeId                            String?
  type                              Type?      @relation(fields: [typeId], references: [id])
  // Admin & Submission fields
  submitterName  String?
  submitterEmail String?
  submitterNote  String?
  status         ToolStatus @default(Draft)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt

  // Relations
  tags          Tag[]
  categories    Category[]
  subcategories Subcategory[]
  subscriptions BrokerSubscription[]
  payments      Payment[]
  claims        BrokerClaim[]
  owner         User?                @relation(fields: [ownerId], references: [id])
  ownerId       String?

  @@index([slug])
  @@index([broker_name])
  @@index([status])
  @@index([ownerId])
  @@index([createdAt])
  @@map("forex_brokers")
}

model Sponsor {
  id         String          @id @default(cuid())
  name       String          @db.Citext
  slug       String?
  logoUrl    String
  websiteUrl String?
  isActive   Boolean         @default(true)
  order      Int             @default(0)
  category   SponsorCategory @default(BrokerListing)
  categoryId String?
  Category   Category?       @relation(fields: [categoryId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  title   String? 
  subtitle String? 
  description String? 
  bannerImage String? 
  features    String[]  
  socialProof String? 
  highlightedPoint String? 
  @@index([isActive, order])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model ContactUs {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model Plan {
  id String @id @default(uuid())

  name        String
  slug        String  @unique
  description String?

  price    Float  @default(0)
  currency String @default("USD")

  durationDays Int

  features String[] // for UI display

  blogPosts        Int  @default(0)
  bannerAds        Int  @default(0)
  featuredLogoDays Int?

  cregisProductId String?

  isActive  Boolean @default(true)
  isPopular Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions BrokerSubscription[]
  payments      Payment[]
  claims        BrokerClaim[]
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  content     String     @db.Text
  image       String?
  publishedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  status      ToolStatus @default(Draft)
  meta_title  String?
  meta_description String?
  og_image String?
  // Relations
  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?
  faqs     FAQ[]

  // Additional fields
  locale String @default("en")

  @@index([slug])
  @@index([status])
  @@index([authorId])
}
model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  postId String?
  post   Post?   @relation(fields: [postId], references: [id])

  @@index([order])
  @@index([isActive])
  @@index([postId])
}

model StandaloneFAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}
model BrokerSubscription {
  id String @id @default(cuid())

  brokerId Int
  broker   Brokers @relation(fields: [brokerId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  startsAt DateTime  @default(now())
  endsAt   DateTime?

  status SubscriptionStatus @default(Active)

  createdAt DateTime @default(now())
}

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  brokerId Int?
  broker   Brokers? @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  amount   Float
  currency String @default("USD")

  gateway String @default("cregis")

  orderId       String? @unique
  transactionId String?

  status PaymentStatus @default(Pending)

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([brokerId])
  @@index([orderId])
}

model BrokerClaim {
  id String @id @default(cuid())

  brokerId Int
  broker   Brokers @relation(fields: [brokerId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status ClaimStatus @default(Pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserConversation {
  id             String @id @default(cuid())
  userId         String
  conversationId String
  sessionId      String
  tool           String
  title          String
}